                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    b.match_id AS MatchId,
    b.inning AS InningNumber,
    b.team AS TeamName,
    b.bowler AS PlayerName,       -- Aliased to PlayerName for the Lookup!
    b.overs AS Overs,
    b.maidens AS Maidens,
    b.runs AS RunsConceded,
    b.wickets AS Wickets,
    b.dots AS Dots,
    m.match_date AS MatchDate,       
    m.ground AS GroundName,          
    b.tournament_year AS TournamentYear, 
    m.series AS SeriesName
FROM dbo.StgBowling b
INNER JOIN dbo.StgMatches m ON b.match_id = m.match_id
WHERE b.bowler IS NOT NULL</property>
