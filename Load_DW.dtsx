              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT PlayerName, TournamentYear, TotalRuns, InningsPlayed, Average, PrevTournamentRuns, IsCurrent, ValidFrom, ValidTo
FROM (
    -- Get the Batters
    SELECT 
        CAST(batter AS VARCHAR(100)) AS PlayerName,
        CAST(tournament_year AS INT) AS TournamentYear,
        CAST(total_runs AS INT) AS TotalRuns,
        CAST(innings_played AS INT) AS InningsPlayed,
        CAST(average AS DECIMAL(9,2)) AS Average,
        CAST(prev_tournament_runs AS DECIMAL(9,2)) AS PrevTournamentRuns,
        CAST(1 AS BIT) AS IsCurrent,       
        CAST('2000-01-01' AS DATE) AS ValidFrom, 
        CAST(NULL AS DATE) AS ValidTo 
    FROM dbo.StgPlayerStats
    WHERE batter IS NOT NULL

    UNION 

    -- Get the Bowlers (we will put NULL for their batting stats for now)
    SELECT 
        CAST(bowler AS VARCHAR(100)) AS PlayerName,
        CAST(tournament_year AS INT) AS TournamentYear,
        NULL AS TotalRuns,
        NULL AS InningsPlayed,
        NULL AS Average,
        NULL AS PrevTournamentRuns,
        CAST(1 AS BIT) AS IsCurrent,       
        CAST('2000-01-01' AS DATE) AS ValidFrom, 
        CAST(NULL AS DATE) AS ValidTo 
    FROM dbo.StgBowling
    WHERE bowler IS NOT NULL
) AS AllPlayers;</property>
