                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    b.match_id AS MatchId,
    b.inning AS InningNumber,
    b.team AS TeamName,
    b.batter AS PlayerName,
    b.runs AS Runs_Clean,
    b.balls AS Balls_Clean,
    b.fours AS Fours_Clean,
    b.sixes AS Sixes_Clean,
