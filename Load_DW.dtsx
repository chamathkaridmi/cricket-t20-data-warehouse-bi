      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F121346C-9A43-4F72-A1C8-16D4603EF612}"
          SQLTask:SqlStatementSource="-- Disable foreign key constraints to allow clearing&#xA;EXEC sp_MSforeachtable &quot;ALTER TABLE ? NOCHECK CONSTRAINT all&quot;;&#xA;&#xA;-- Clear Fact Tables first&#xA;DELETE FROM dbo.Match_Fact;&#xA;&#xA;-- Clear Dimension Tables&#xA;DELETE FROM dbo.DimPlayer;&#xA;DELETE FROM dbo.DimTeam;&#xA;DELETE FROM dbo.DimTournament;&#xA;DELETE FROM dbo.DimVenue;&#xA;&#xA;-- Enable foreign key constraints back&#xA;EXEC sp_MSforeachtable &quot;ALTER TABLE ? WITH CHECK CHECK CONSTRAINT all&quot;;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
